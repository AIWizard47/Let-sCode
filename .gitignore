# =====================================================
# Django / Python .gitignore
# =====================================================

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*
**/.env
**/.env.*

# Secret Keys
*.pem
*.key
*.crt
*.p12

# ----------------------------
# Virtual Environments
# ----------------------------
venv/
.venv/
env/
ENV/
virtualenv/

**/venv/
**/.venv/
**/env/
**/ENV/

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution
build/
dist/
*.egg-info/
.eggs/

# ----------------------------
# Django
# ----------------------------
db.sqlite3
db.sqlite3-journal

media/
staticfiles/

*.log
logs/
*.pid

# Local settings
local_settings.py

# ----------------------------
# Migrations (Optional)
# Keep __init__.py
# Uncomment if you don't want migrations in Git
# ----------------------------
# */migrations/*
# !*/migrations/__init__.py

# ----------------------------
# Testing
# ----------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/

# ----------------------------
# Type Checking
# ----------------------------
.mypy_cache/
.pyre/
.pytype/

# ----------------------------
# Jupyter
# ----------------------------
.ipynb_checkpoints/

# ----------------------------
# VS Code
# ----------------------------
.vscode/

# ----------------------------
# PyCharm
# ----------------------------
.idea/

# ----------------------------
# macOS
# ----------------------------
.DS_Store

# ----------------------------
# Windows
# ----------------------------
Thumbs.db
Desktop.ini

# ----------------------------
# Linux
# ----------------------------
*~

# ----------------------------
# Cache
# ----------------------------
.cache/
.pytest_cache/

# ----------------------------
# Celery
# ----------------------------
celerybeat-schedule
celerybeat.pid

# ----------------------------
# Redis Dump
# ----------------------------
dump.rdb

# ----------------------------
# Temporary Files
# ----------------------------
tmp/
temp/
*.tmp

# ----------------------------
# Node (if using Tailwind, Vite, React, etc.)
# ----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ----------------------------
# Compiled Files
# ----------------------------
*.exe
*.dll
*.o
*.obj
*.class